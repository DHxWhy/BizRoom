# ══════════════════════════════════════════════════════════════
# BizRoom.ai — Environment Variables
# Copy to backend/.env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# ─── Azure AI Foundry Model Router (Primary — Hero Tech) ────
# Intelligent multi-model routing: quality/cost/balanced modes
# Supports GPT-5.x, GPT-4.1, DeepSeek, Claude, Grok via single endpoint
# Uncomment when Foundry deployment quota is approved
# AZURE_FOUNDRY_MODEL_ROUTER_ENDPOINT=https://<your-resource>.openai.azure.com/openai/deployments/model-router
# AZURE_FOUNDRY_API_KEY=

# ─── Anthropic API (Fallback Provider) ──────────────────────
# Claude Opus 4.6: agent conversation, meeting minutes, summaries
# Claude Sonnet 4.6: Sophia visualization, artifact generation
# Claude Haiku 4.5: topic classification, mention parsing
ANTHROPIC_API_KEY=
# Optional model overrides (defaults to latest):
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6-20250929
# ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6-20250514
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ─── OpenAI API (Fallback Provider) ─────────────────────────
# gpt-realtime-1.5: real-time voice meeting (STT+LLM+TTS)
# o3: deep reasoning, financial analysis, risk assessment
OPENAI_API_KEY=
# Optional model overrides:
# OPENAI_MODEL_REALTIME=gpt-realtime-1.5
# OPENAI_MODEL_REASONING=o3
# OPENAI_MODEL_PREMIUM=gpt-4o
# OPENAI_MODEL_FAST=gpt-4o-mini

# ─── Azure SignalR Service ──────────────────────────────────
# Real-time communication: agent streaming, typing indicators,
# big screen updates, chairman monitor
AZURE_SIGNALR_CONNECTION_STRING=

# ─── Azure OpenAI (Legacy / Direct Deployment) ─────────────
# Used when models are deployed directly on Azure OpenAI Service
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT_PREMIUM=
# AZURE_OPENAI_DEPLOYMENT_FAST=
